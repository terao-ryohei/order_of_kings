{
  "name": "imperial-command",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build && cp -r server build/client/ && cp load-context.ts build/client/load-context.js && node scripts/build-worker-entry.mjs",
    "dev": "remix vite:dev",
    "start": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "pages:dev": "wrangler dev",
    "typecheck": "tsc",
    "generate": "drizzle-kit generate",
    "local:migration": "wrangler d1 migrations apply imperial-command-db --local",
    "remote:migration": "wrangler d1 migrations apply imperial-command-db --remote"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.30.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@remix-run/cloudflare": "^2.17.2",
    "@remix-run/node": "^2.17.2",
    "@remix-run/react": "^2.17.2",
    "@remix-run/serve": "^2.17.2",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.6",
    "hono-remix-adapter": "^0.5.4",
    "isbot": "^5.1.32",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251126.0",
    "@hono/vite-dev-server": "^0.23.0",
    "@remix-run/dev": "^2.17.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.50.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
